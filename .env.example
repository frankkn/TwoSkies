# Firebase Web App 設定（Firebase console → 專案設定 → 一般 → 你的應用程式）
# 複製成 .env.local 填入；全部留空＝假資料模式（本地原型）
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# App Check 的 reCAPTCHA v3 site key（公開值；留空＝不啟用 App Check）
VITE_RECAPTCHA_SITE_KEY=

# 1 = 連本地 emulator（先跑 npm run emulators）
VITE_USE_EMULATORS=

# 1 = 強制假資料模式（不碰 Firebase）
VITE_USE_MOCK=
